# Database configs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

POSTGRES_DB=cinematch
#POSTGRES_HOST=localhost # local db server
POSTGRES_HOST=db # docker db
POSTGRES_PORT=5432

# FastAPI configs
VERSION_NR=0.3
SWAGGER_THEME=obsidian
TITLE=CinematchAPI

# uvicorn configs
MODULE_NAME=main:app
HOST=0.0.0.0
PORT=8000
DEV_MODE=0 #1=Ture, 0=False

# SSL confis (this woll most likely not be used)
SSL_KEYFILE=tbd
SSL_CERTFILE=tbd

# model service configs
#MODEL_SERVICE_URL=http://127.0.0.1:8001
MODEL_SERVICE_URL=http://model-service:8001